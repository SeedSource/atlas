# Fast-path: layer a pre-built spark binary on top of the previous alpha image.
# Avoids the multi-minute Cargo dep fetch + release build by reusing the
# existing Ubuntu + CUDA runtime layers from the last alpha.
#
# Build (host must have `target/release/spark` already built):
#   cargo build --release -p spark-server
#   cp target/release/spark spark-fastbin
#   docker build -f docker/gb10/Dockerfile.fast -t atlas-gb10:alpha-2.14 .
#
# The `target/` directory is in .dockerignore, so we stage the binary as
# `spark-fastbin` at the repo root for the build context.

FROM atlas-gb10:fix42

COPY spark-fastbin /usr/local/bin/spark
COPY jinja-templates/ /jinja-templates/
